[Unit]
Description=ZRouter - Anthropic API Routing Daemon
After=network.target

[Service]
Type=simple
ExecStart=/usr/local/bin/zrouter --config /etc/zrouter/config.toml
Restart=on-failure
RestartSec=5

# Security hardening
NoNewPrivileges=true
ProtectSystem=strict
ProtectHome=true
PrivateTmp=true

# Environment file for provider API keys
EnvironmentFile=-/etc/zrouter/env

[Install]
WantedBy=multi-user.target
